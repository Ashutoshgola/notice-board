// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
// prisma/schema.prisma

datasource db {
  provider = "mysql" // Change to "postgresql" if you use Neon/Supabase instead of TiDB Cloud
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Category {
  Exam
  Event
  General
}

enum Priority {
  Normal
  Urgent
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String   // Short text. Required.
  body        String   @db.Text // Longer text. Required.
  category    Category // Dropdown option
  priority    Priority // Normal or Urgent
  publishDate DateTime // Valid date mapping
  image       String?  // Optional image string (Bonus feature)
  createdAt   DateTime @default(now())
}